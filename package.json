{
	"name": "vocawiki-frontend",
	"scripts": {
		"format": "oxfmt",
		"check:type": "tsc --project tsconfig.app.json --noEmit && tsc --project tsconfig.node.json --noEmit",
		"check:lint": "eslint .",
		"check": "pnpm run check:type && pnpm run check:lint",
		"dev": "bun run --bun --tsconfig-override tsconfig.node.json scripts/dev && vite scripts/dev/site",
		"build": "bun run --bun --tsconfig-override tsconfig.node.json scripts/build",
		"deploy": "bun run --bun --tsconfig-override tsconfig.node.json scripts/deploy",
		"before-commit": "pnpm run format && pnpm run check && pnpm run build"
	},
	"private": true,
	"type": "module",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bun": "^1.3.10",
		"@types/express": "^5.0.6",
		"@types/fs-extra": "^11.0.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitejs/plugin-rsc": "^0.5.21",
		"bun": "^1.3.10",
		"eslint": "^10.0.3",
		"express": "^5.2.1",
		"fs-extra": "^11.3.4",
		"globals": "^17.4.0",
		"globby": "^16.1.1",
		"lightningcss": "^1.32.0",
		"oxfmt": "^0.40.0",
		"postcss": "^8.5.8",
		"radashi": "^12.7.2",
		"react-dom": "^19.2.4",
		"rolldown": "1.0.0-rc.9",
		"rsc-html-stream": "^0.0.7",
		"tailwindcss": "^4.2.1",
		"type-fest": "^5.4.4",
		"types-mediawiki": "^2.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "8.0.0",
		"wiki-saikou": "^7.6.0",
		"zod": "^4.3.6"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"dependencies": {
		"clsx": "^2.1.1",
		"fast-average-color": "^9.5.0",
		"react": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"ts-md5": "^2.0.1"
	}
}

{
	"name": "vocawiki-frontend",
	"scripts": {
		"format": "oxfmt",
		"check:type": "tsc --noEmit",
		"check:lint": "eslint .",
		"check": "pnpm run check:type && pnpm run check:lint",
		"build": "bun run --bun --tsconfig-override ./tsconfig.node.json ./scripts/build",
		"deploy": "bun run --bun --tsconfig-override ./tsconfig.node.json ./scripts/deploy",
		"before-commit": "pnpm run format && pnpm run check && pnpm run build"
	},
	"private": true,
	"type": "module",
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/bun": "^1.3.9",
		"@types/fs-extra": "^11.0.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"bun": "^1.3.10",
		"eslint": "^9.39.3",
		"eslint-plugin-react": "^7.37.5",
		"fs-extra": "^11.3.3",
		"globals": "^17.4.0",
		"oxfmt": "^0.36.0",
		"postcss": "^8.5.6",
		"radashi": "^12.7.2",
		"react-dom": "^19.2.4",
		"rolldown": "1.0.0-rc.6",
		"sass-embedded": "^1.97.3",
		"tailwindcss": "^4.2.1",
		"type-fest": "^5.4.4",
		"types-mediawiki": "^2.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"wiki-saikou": "^7.6.0",
		"zod": "^4.3.6"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"dependencies": {
		"clsx": "^2.1.1",
		"fast-average-color": "^9.5.0",
		"react": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"ts-md5": "^2.0.1"
	}
}
